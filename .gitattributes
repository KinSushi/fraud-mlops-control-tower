# Normalize line endings across Windows/Linux/macOS
* text=auto eol=lf

# Shell / config
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.sql text eol=lf
*.py text eol=lf
*.md text eol=lf
*.svg text eol=lf
*.json text eol=lf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
